# Safe placeholders only. Do not commit real tokens or local secrets.

GITHUB_OWNER=TeamFloPay
GITHUB_PROJECT_NUMBER=1
GITHUB_PROJECT_TITLE=Campaign Map

# Local LLM launcher used by future War Room handoffs.
# Supported values: codex, claude
LLM_ADAPTER=codex

# Optional command paths if they are not on PATH. For Codex, provide the
# executable only. War Room disables Codex Fast Mode by default and pins
# gpt-5.5/xhigh for both non-interactive and interactive handoffs.
# Codex Desktop on macOS commonly bundles it at:
# /Applications/Codex.app/Contents/Resources/codex
CODEX_COMMAND=codex
CLAUDE_COMMAND=claude

CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
CODEX_FAST_MODE=false

# Interactive issue triage needs outbound DNS/API access for read-only checks
# like Stripe investigation while keeping filesystem access workspace-scoped.
# Set CODEX_INTERACTIVE_SANDBOX=danger-full-access only for exceptional cases.
CODEX_INTERACTIVE_SANDBOX=workspace-write
CODEX_INTERACTIVE_NETWORK_ACCESS=true

# Claude adapter settings (used when LLM_ADAPTER=claude).
# War Room runs foreground handoffs as `claude --print --output-format json
# --model <CLAUDE_MODEL> --permission-mode <CLAUDE_PERMISSION_MODE>` with the
# prompt on stdin, and interactive handoffs as `claude --model <CLAUDE_MODEL>
# --permission-mode <CLAUDE_INTERACTIVE_PERMISSION_MODE> <prompt>`.
# Permission modes: default | acceptEdits | bypassPermissions | plan.
# acceptEdits is the closest match to Codex --sandbox workspace-write;
# bypassPermissions is the analog of --sandbox danger-full-access.
CLAUDE_MODEL=claude-sonnet-4-6 # claude-opus-4-7 is also a good choice if available in your environment
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_INTERACTIVE_PERMISSION_MODE=acceptEdits

# Optional PR merge e2e gate overrides. Local HTTPS health checks accept
# untrusted certificates for localhost, loopback, and *.local.flopay.com by
# default so War Room can reuse a running local API behind local TLS.
WARROOM_MERGE_BACKEND_BASE_URL=https://api.local.flopay.com
WARROOM_MERGE_BACKEND_READY_PATH=/v1/health
WARROOM_MERGE_BACKEND_READY_PROBE_TIMEOUT_MS=3000
WARROOM_MERGE_BACKEND_ALLOW_INSECURE_LOCAL_TLS=true
WARROOM_MERGE_BACKEND_STRICT_TLS=false
WARROOM_MERGE_DEMO_USE_SYSTEM_CA=true

# Optional repo-local plugin/MCP auth. Use real values only in .env.local or
# your shell environment; these placeholders are intentionally empty.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
RAILWAY_TOKEN=

# Provider/API keys belong in .env.local, ally-specific .env.local files,
# 1Password, Doppler, SOPS, or the relevant MCP/tool configuration. They must
# not be committed here.



# Slack bot token for changelog distribution (warroom changelog share).
# Create a FloBot app in the TeamFloPay workspace and grant chat:write scope.
SLACK_BOT_TOKEN=xoxb-your-token-here

# Sentry tokens for LLM Adapter error monitoring. These are optional, but recommended for better visibility into issues.
# SENTRY_DSN live in each repo's .env.local, but these are the org-level tokens that can be used across all repos if desired.
SENTRY_ORG="example-org"
SENTRY_AUTH_TOKEN="example-auth-token"
