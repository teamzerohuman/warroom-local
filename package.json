{
  "name": "warroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local command center and cross-repo orchestration workspace.",
  "bin": {
    "warroom": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "link:global": "npm run build && npm link",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "warroom": "tsx src/cli.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^12.1.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@sentry/cli": "^3.4.2",
    "@types/node": "^22.18.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
