.DS_Store
node_modules/
dist/
coverage/

# Local secrets and machine-specific config.
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# Project-specific War Room config. The shared War Room (parent) ships only the
# `*.example` templates; each consuming project generates these via `warroom
# setup` so its repos/allies/maps never travel upstream. Keep the templates.
repos.yaml
allies.yaml
maps/campaign-atlas.md
maps/issue-territory.md

# Local command artifacts.
.warroom/runs/*
!.warroom/runs/.gitkeep
.warroom/dev/*
!.warroom/dev/.gitkeep
.warroom/changelog-share-state.json

# Ally secrets, local client repo checkouts, and machine-specific workspace state.
allies/*/.env.local
allies/*/repos/*
allies/*/workspace/*

# Child repositories are cloned locally and committed in their own repos.
maps/repos/*
!maps/repos/.gitkeep
allies/*

# Tool caches.
.turbo/
.vitest/
npm-debug.log*

/error.log